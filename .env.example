# ═══════════════════════════════════════════════════════
# Business Dashboard — Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# Only fill in the sections for modules you've enabled
# in config.json.

# ─── Required (always needed) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Google (Calendar + Email + Drive) ────────────────
# Create OAuth credentials at console.cloud.google.com
# Enable: Gmail API, Google Calendar API, Google Drive API
GMAIL_CLIENT_ID=your_client_id
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token

# ─── Stripe (Revenue module) ─────────────────────────
# Get from dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_or_sk_test_xxx

# ─── Instagram (Content Analytics module) ─────────────
# Long-lived token from Facebook Developer portal
# Refresh every 60 days
IG_ACCESS_TOKEN=your_ig_token
IG_USER_ID=your_ig_user_id

# ─── Competitors (Competitor Intelligence module) ─────
# Get from console.apify.com/account/integrations
APIFY_API_TOKEN=your_apify_token

# ─── Facebook Ads (Ads module) ────────────────────────
# Long-lived token from Facebook Developer portal
META_ACCESS_TOKEN=your_meta_token
META_APP_ID=your_meta_app_id

# ─── AI Features (Email triage + Caption generation) ──
# At least one is needed for AI-powered features
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key

# ─── Content Scheduling (Zernio) ─────────────────────
# Get from your Zernio account settings
ZERNIO_API_KEY=your_zernio_key

# ─── Cron Jobs (Vercel cron authorization) ────────────
# Random string used to authenticate cron endpoints
CRON_SECRET=your_random_secret_string
